# ═══════════════════════════════════════════════════════
# Discord Watchdog Alerts — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# ── Discord Bot ────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token-here

# Comma-separated Discord user snowflake IDs to monitor
WATCHED_USER_IDS=123456789012345678,987654321098765432

# Comma-separated Discord channel/thread snowflake IDs to watch
WATCHED_CHANNEL_IDS=111111111111111111,222222222222222222

# ── Notifier Selection ─────────────────────────────────
# Which notifier to use as primary: telegram | pushover | sms | email
NOTIFIER=telegram

# Optional — fallback chain (comma-separated, tried in order on primary failure)
FALLBACK_NOTIFIERS=pushover,email

# ── Telegram ────────────────────────────────────────────
# Create a bot via @BotFather, get the token and your chat ID
#TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
#TELEGRAM_CHAT_ID=123456789

# ── Pushover ────────────────────────────────────────────
# Register at https://pushover.net
#PUSHOVER_USER_KEY=uXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
#PUSHOVER_APP_TOKEN=aXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── SMS (Twilio) ────────────────────────────────────────
# Sign up at https://twilio.com
#TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#TWILIO_AUTH_TOKEN=your-twilio-auth-token
#TWILIO_FROM_PHONE=+12025551234
#TWILIO_TO_PHONE=+48123456789

# ── Email (SMTP) ────────────────────────────────────────
# Works with SendGrid, Mailgun, Gmail SMTP, or any SMTP server
#SMTP_HOST=smtp.sendgrid.net
#SMTP_PORT=587
#SMTP_USER=apikey
#SMTP_PASS=SG.your-sendgrid-api-key
#SMTP_FROM=alerts@example.com
#SMTP_TO=you@example.com
