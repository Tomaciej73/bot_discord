# Discord Watchdog Alerts
# Copy this file to .env and fill in real values.
# Do not commit .env files with real tokens.

# Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token-here

# Comma-separated Discord user IDs to monitor.
WATCHED_USER_IDS=123456789012345678,987654321098765432

# Comma-separated exact Discord channel or thread IDs to monitor.
# For fastest and safest filtering, put the exact "picks" channel/thread ID here.
WATCHED_CHANNEL_IDS=111111111111111111,222222222222222222

# Optional. If "picks" is a forum post/thread and you want all threads under
# a parent forum/channel monitored, put parent channel IDs here.
WATCHED_PARENT_CHANNEL_IDS=

# Primary notifier: telegram | pushover | sms | email
NOTIFIER=telegram

# Optional fallback chain. Tried in order only if the primary notifier fails.
FALLBACK_NOTIFIERS=pushover,email

# Telegram
# Create a bot with @BotFather, then get your chat ID.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# Pushover
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# SMS via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
TWILIO_TO_PHONE=

# Email via SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
